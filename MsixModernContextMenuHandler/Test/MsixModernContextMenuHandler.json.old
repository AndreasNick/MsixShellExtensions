{
  "clsid": "{4A7B3C1D-E2F5-4689-ABCD-EF1234567891}",
  "menuTitle": "WinRAR",
  "executable": "WinRAR.exe",
  "psfLauncher": "",
  "icon": "WinRAR.exe",
  "iconIndex": 0,
  "iconSize": 0,
  "archiveExtension": ".rar",
  "debug": false,
  "allFiles": true,
  "folders": true,
  "background": false,
  "recycleBin": false,
  "fileTypes": [],
  "entries": [
    {
      "id": "addToArchive",
      "label": "Add to archive...",
      "labelWithFile": "Add to \"{archive}\"...",
      "args": "a \"{archive}\" {files}",
      "filesOnly": false,
      "useShellExecute": false,
      "extensions": []
    },
    {
      "id": "addToRar",
      "label": "Add to RAR archive",
      "labelWithFile": "",
      "args": "a -ep1 \"{archive}\" {files}",
      "filesOnly": false,
      "useShellExecute": false,
      "extensions": []
    },
    {
      "id": "addToZip",
      "label": "Add to ZIP archive",
      "labelWithFile": "",
      "args": "a -afzip \"{archive}.zip\" {files}",
      "filesOnly": false,
      "useShellExecute": false,
      "extensions": []
    },
    {
      "id": "extractHere",
      "label": "Extract here",
      "labelWithFile": "Extract here",
      "args": "x {files} \"{folder}\\\"",
      "filesOnly": true,
      "useShellExecute": false,
      "extensions": [".rar", ".zip", ".7z", ".tar", ".gz", ".bz2", ".xz", ".cab", ".arj"]
    },
    {
      "id": "extractTo",
      "label": "Extract to...",
      "labelWithFile": "Extract to...",
      "args": "e {files}",
      "filesOnly": true,
      "useShellExecute": false,
      "extensions": [".rar", ".zip", ".7z", ".tar", ".gz", ".bz2", ".xz", ".cab", ".arj"]
    },
    {
      "id": "openArchive",
      "label": "Open with WinRAR",
      "labelWithFile": "Open \"{archive}\" with WinRAR",
      "args": "{files}",
      "filesOnly": true,
      "useShellExecute": false,
      "extensions": [".rar", ".zip", ".7z", ".tar", ".gz", ".bz2", ".xz", ".cab", ".arj"]
    }
  ]
}
